<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="App6.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:App6"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:essential="using:WinUI3Package"
    xmlns:local="using:App6"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border>
        <ScrollViewer>
            <StackPanel Margin="50,20,50,0" Spacing="3">

                <essential:SettingsCard x:Uid="ViewPageSettingsStealthMode">
                    <ToggleSwitch
                        MinWidth="10"
                        IsOn="{x:Bind ViewModel.StealthMode, Mode=TwoWay}"
                        Style="{ThemeResource RightAlignedCompactToggleSwitchStyle}" />
                    <essential:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xED1A;" />
                    </essential:SettingsCard.HeaderIcon>
                </essential:SettingsCard>

                <essential:SettingsCard x:Uid="ViewPageSettingsRestrictedTokens">
                    <ToggleSwitch
                        MinWidth="10"
                        IsOn="{x:Bind ViewModel.RestrictedTokens, Mode=TwoWay}"
                        Style="{ThemeResource RightAlignedCompactToggleSwitchStyle}" />
                    <essential:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xF0EF;" />
                    </essential:SettingsCard.HeaderIcon>
                </essential:SettingsCard>

                <essential:SettingsCard x:Uid="ViewPageSettingsLanguageOverride">

                    <StackPanel Orientation="Horizontal" Spacing="160">
                        <ComboBox
                            x:Name="LangCombo"
                            MinWidth="200"
                            Width="auto"
                            essential:ComboBoxHelper.AcrylicWorkaround="True"
                            IsEnabled="{x:Bind LangOverrideToggle.IsOn, Mode=OneWay}"
                            ItemsSource="{x:Bind ViewModel.Languages}"
                            SelectionChanged="LangCombo_SelectionChanged" />
                        <ToggleSwitch
                            x:Name="LangOverrideToggle"
                            MinWidth="10"
                            IsOn="{x:Bind ViewModel.LangOverride, Mode=TwoWay}"
                            Style="{ThemeResource RightAlignedCompactToggleSwitchStyle}" />
                    </StackPanel>

                    <essential:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xF2B7;" />
                    </essential:SettingsCard.HeaderIcon>
                </essential:SettingsCard>

                <essential:SettingsExpander x:Uid="ViewPageSettingsIslandRestrictionsOverride" IsExpanded="{x:Bind IslandRestrictionsOverrideToggle.IsOn, Mode=OneWay}">
                    <ToggleSwitch
                        x:Name="IslandRestrictionsOverrideToggle"
                        MinWidth="10"
                        IsOn="{x:Bind ViewModel.IslandRestrictionsOverride, Mode=TwoWay}"
                        Style="{ThemeResource RightAlignedCompactToggleSwitchStyle}" />
                    <essential:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE785;" />
                    </essential:SettingsExpander.HeaderIcon>

                    <essential:SettingsExpander.Items>

                        <essential:SettingsCard x:Uid="ViewPageSettingsFrameRateLimitOverride" IsEnabled="{x:Bind IslandRestrictionsOverrideToggle.IsOn, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="160">
                                <NumberBox
                                    MinWidth="160"
                                    Padding="12,6,0,0"
                                    VerticalAlignment="Center"
                                    IsEnabled="{x:Bind FrameRateLimitOverrideToggle.IsOn, Mode=OneWay}"
                                    LargeChange="10"
                                    Maximum="10000"
                                    Minimum="1"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{x:Bind ViewModel.FrameRateLimitValue, Mode=TwoWay}" />
                                <ToggleSwitch
                                    x:Name="FrameRateLimitOverrideToggle"
                                    MinWidth="10"
                                    IsOn="{x:Bind ViewModel.FrameRateLimitOverride, Mode=TwoWay}"
                                    Style="{ThemeResource RightAlignedCompactToggleSwitchStyle}" />
                            </StackPanel>

                        </essential:SettingsCard>

                    </essential:SettingsExpander.Items>
                </essential:SettingsExpander>


                <essential:SettingsExpander x:Uid="ViewPageSettingsGamePath" IsExpanded="True">

                    <essential:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE7C3;" />
                    </essential:SettingsExpander.HeaderIcon>

                    <essential:SettingsExpander.Items>

                        <essential:SettingsCard
                            x:Uid="ViewPageSettingsSelectGamePath"
                            Click="SelectGamePath_Click"
                            IsClickEnabled="True">
                            <Button
                                x:Uid="ViewPageSettingsGamePathAutoDetect"
                                Click="GamePathAutoDetect_Click"
                                Style="{StaticResource AccentButtonStyle}" />
                        </essential:SettingsCard>

                        <essential:SettingsCard ContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Uid="ViewPageSettingsGamePathTextBlock" VerticalAlignment="Center" />
                                <TextBox
                                    x:Name="GamePathText"
                                    x:Uid="ViewPageSettingsGamePathTextBox"
                                    MinWidth="600"
                                    Margin="20,0,0,0"
                                    Text="{x:Bind ViewModel.GamePath, Mode=TwoWay}" />
                            </StackPanel>

                        </essential:SettingsCard>

                    </essential:SettingsExpander.Items>
                </essential:SettingsExpander>

                <essential:SettingsCard x:Uid="ViewPageSettingsCloseButtonBehavior">
                    <ComboBox
                        x:Name="LangCombo0"
                        Width="150"
                        essential:ComboBoxHelper.AcrylicWorkaround="True"
                        ItemsSource="{x:Bind ViewModel.CloseBehaviors}"
                        SelectedIndex="{x:Bind ViewModel.CloseBehaviorIndex, Mode=TwoWay}" />
                    <essential:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE711;" />
                    </essential:SettingsCard.HeaderIcon>
                </essential:SettingsCard>

                <essential:SettingsCard x:Uid="ViewPageSettingsCrashDump">
                    <ToggleSwitch
                        MinWidth="10"
                        IsOn="True"
                        Style="{ThemeResource RightAlignedCompactToggleSwitchStyle}" />
                    <essential:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEBE8;" />
                    </essential:SettingsCard.HeaderIcon>
                </essential:SettingsCard>

            </StackPanel>

        </ScrollViewer>
    </Border>
</Page>
